# RoomSync Environment Variables Template
# Copy this file to a new file named '.env' and fill in the values.

# Flask Security (Required for sessions)
SECRET_KEY=generate_a_random_string_here

# Database Configuration (Required)
# Local development and production both use PostgreSQL.
# Example: postgresql://user:password@localhost:5432/room_sync
DATABASE_URL=your_postgresql_url_here

# Anthropic Claude API (Required for receipt scanning)
# Get this from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Postgres (Only needed if testing production-like DB locally)
POSTGRES_URL=your_vercel_postgres_url_here

# Google OAuth (Required for Google Sign-In)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# Stripe (Required for payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here
